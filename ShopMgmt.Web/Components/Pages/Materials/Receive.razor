@page "/materials/{MaterialId:int}/receive"
@rendermode InteractiveServer
@inject MaterialApiClient Materials
@inject StockBatchApiClient Batches
@inject NavigationManager Nav

<PageTitle>Receive Stock</PageTitle>

<h1>Receive stock</h1>

@if (_material is not null)
{
    <p>Material: <strong>@_material.Name</strong> — on hand: @_material.OnHand.ToString("N2") @_material.Unit</p>
}

@if (!string.IsNullOrEmpty(_error))
{
    <p class="error">@_error</p>
}

<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <div class="form-group">
        <label>Quantity received</label>
        <InputNumber @bind-Value="_model.QuantityReceived" class="form-control" />
    </div>
    <div class="form-group">
        <label>Received at</label>
        <InputDate @bind-Value="_receivedDate" class="form-control" />
    </div>
    <div class="form-group">
        <label>Expiry date (optional)</label>
        <InputDate @bind-Value="_expiryDate" class="form-control" />
    </div>
    <div class="form-group">
        <label>Cost total</label>
        <InputNumber @bind-Value="_model.CostTotal" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary" disabled="@_saving">Receive</button>
    <a class="btn" href="materials">Back to list</a>
</EditForm>

@if (_history.Count > 0)
{
    <h2>Recent batches</h2>
    <table class="data-table">
        <thead>
            <tr>
                <th>Received</th>
                <th class="num">Qty</th>
                <th class="num">Cost</th>
                <th>Expiry</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in _history)
            {
                <tr>
                    <td>@b.ReceivedAt.ToLocalTime().ToString("g")</td>
                    <td class="num">@b.QuantityReceived.ToString("N2")</td>
                    <td class="num">@b.CostTotal.ToString("N2")</td>
                    <td>@(b.ExpiryDate?.ToString("d") ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public int MaterialId { get; set; }

    private MaterialDetailDto? _material;
    private CreateStockBatchDto _model = new() { ReceivedAt = DateTime.UtcNow };
    private DateTime _receivedDate = DateTime.Today;
    private DateTime? _expiryDate;
    private List<StockBatchDto> _history = [];
    private string? _error;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _material = await Materials.GetByIdAsync(MaterialId);
        _history = (await Batches.GetByMaterialIdAsync(MaterialId)).ToList();
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            _model.ReceivedAt = _receivedDate.ToUniversalTime();
            _model.ExpiryDate = _expiryDate?.ToUniversalTime();

            var created = await Batches.ReceiveAsync(MaterialId, _model);
            if (created is null)
            {
                _error = "Failed to receive stock.";
                return;
            }

            _material = await Materials.GetByIdAsync(MaterialId);
            _history = (await Batches.GetByMaterialIdAsync(MaterialId)).ToList();
            _model = new CreateStockBatchDto { ReceivedAt = DateTime.UtcNow };
            _receivedDate = DateTime.Today;
            _expiryDate = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
