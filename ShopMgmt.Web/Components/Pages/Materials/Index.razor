@page "/materials"
@rendermode InteractiveServer
@inject MaterialApiClient Materials
@implements IAsyncDisposable

<PageTitle>Materials</PageTitle>

<div class="page-header">
    <h1>Materials</h1>
    <div>
        <button class="btn" @onclick="LoadAsync" disabled="@_loading">Refresh</button>
        <a class="btn btn-primary" href="materials/create">Add material</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <p class="error">@_error</p>
}

@if (_loading && _items.Count == 0)
{
    <p>Loading…</p>
}
else
{
    <p class="muted">Auto-refresh every @_pollSeconds seconds. Last updated: @_lastUpdated.ToLocalTime().ToString("T")</p>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Unit</th>
                <th class="num">Unit price</th>
                <th class="num">On hand</th>
                <th class="num">Stock value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in _items.OrderBy(x => x.Name))
            {
                <tr>
                    <td>@m.Name</td>
                    <td>@m.CategoryName</td>
                    <td>@m.Unit</td>
                    <td class="num">@m.UnitPrice.ToString("N2")</td>
                    <td class="num">@m.OnHand.ToString("N2")</td>
                    <td class="num highlight">@m.StockValue.ToString("N2")</td>
                    <td class="actions">
                        <a href="materials/edit/@m.MaterialId">Edit</a>
                        <a href="materials/@m.MaterialId/receive">Receive</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private const int _pollSeconds = 12;
    private readonly List<MaterialListItemDto> _items = [];
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;
    private bool _loading = true;
    private string? _error;
    private DateTime _lastUpdated;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(_pollSeconds));
        _ = PollAsync(_cts.Token);
    }

    private async Task PollAsync(CancellationToken token)
    {
        if (_timer is null) return;
        try
        {
            while (await _timer.WaitForNextTickAsync(token))
            {
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var list = await Materials.GetAllAsync();
            _items.Clear();
            _items.AddRange(list);
            _lastUpdated = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load materials: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _timer?.Dispose();
    }
}
