@page "/materials/edit/{Id:int}"
@rendermode InteractiveServer
@inject MaterialApiClient Materials
@inject CategoryApiClient Categories
@inject NavigationManager Nav

<PageTitle>Edit Material</PageTitle>

<h1>Edit material</h1>

@if (!string.IsNullOrEmpty(_error))
{
    <p class="error">@_error</p>
}

@if (_loading)
{
    <p>Loading…</p>
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <div class="form-group">
            <label>Name</label>
            <InputText @bind-Value="_model.Name" class="form-control" />
        </div>
        <div class="form-group">
            <label>Category</label>
            <InputSelect @bind-Value="_model.CategoryId" class="form-control">
                @foreach (var c in _categories)
                {
                    <option value="@c.CategoryId">@c.Name</option>
                }
            </InputSelect>
        </div>
        <div class="form-group">
            <label>Unit price</label>
            <InputNumber @bind-Value="_model.UnitPrice" class="form-control" />
        </div>
        <div class="form-group">
            <label>Unit</label>
            <InputText @bind-Value="_model.Unit" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@_saving">Save</button>
        <a class="btn" href="materials">Cancel</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private UpdateMaterialDto _model = new();
    private List<CategoryDto> _categories = [];
    private string? _error;
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _categories = (await Categories.GetAllAsync()).ToList();
        var detail = await Materials.GetByIdAsync(Id);
        if (detail is null)
        {
            _error = "Material not found.";
            _loading = false;
            return;
        }

        _model = new UpdateMaterialDto
        {
            Name = detail.Name,
            CategoryId = detail.CategoryId,
            UnitPrice = detail.UnitPrice,
            Unit = detail.Unit
        };
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            var updated = await Materials.UpdateAsync(Id, _model);
            if (updated is null)
            {
                _error = "Failed to update material.";
                return;
            }

            Nav.NavigateTo("materials");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
